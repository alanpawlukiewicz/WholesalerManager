@{
    ViewBag.Title = "Error";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-danger text-center">
                <div class="card-header bg-danger-subtle py-4 border-danger">
                    <div class="mb-3 text-danger">
                        <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="currentColor" class="bi bi-exclamation-triangle-fill" viewBox="0 0 16 16">
                            <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2" />
                        </svg>
                    </div>
                    <h1 class="h3 mb-0 text-danger fw-bold">An Error Has Occurred</h1>
                </div>

                <div class="card-body p-4">
                    <p class="text-muted fs-5 mb-4">
                        We're sorry, but something went wrong while processing your request.
                    </p>

                    <div class="d-flex justify-content-center gap-2">
                        <a href="javascript:history.back()" class="btn btn-outline-secondary px-4">
                            Go Back
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
                            Home Dashboard
                        </a>
                    </div>
                </div>

                <div class="card-footer bg-light py-3 text-muted small border-top-0">
                    If this problem persists, please contact your system administrator.
                </div>
            </div>
        </div>
    </div>
</div>