@model IEnumerable<DeliveryWithProductsViewModel>
@{
    ViewBag.Title = "Deliveries";
}

<div class="container-fluid px-4 my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Deliveries</h1>
        @if (User.IsInRole(UserTypeOptions.Administrator.ToString()) || User.IsInRole(UserTypeOptions.Manager.ToString()))
        {
            <a asp-controller="Deliveries" asp-action="Create" class="btn btn-success d-inline-flex align-items-center gap-2">
                Register New Delivery
            </a>
        }
    </div>

    @await Component.InvokeAsync("FilterSearchBar", new { controllerName = "Deliveries", actionName = "Index" })

    <div class="table-responsive shadow-sm rounded border">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(DeliveryResponse.SupplierName) })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(DeliveryResponse.OrderDate) })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(DeliveryResponse.Status) })
                    <th colspan="2" class="text-end px-4" style="width: 200px;">Actions</th>
                </tr>
            </thead>

            @foreach (var dwp in Model)
            {
                <tbody class="delivery-record border-bottom border-light-subtle">
                    <tr class="table-group-divider border-light-subtle">
                        <td class="fw-bold text-primary">
                            @dwp.Delivery?.SupplierName
                        </td>
                        <td>
                            @dwp.Delivery?.OrderDate
                        </td>
                        <td>
                            @if (dwp.Delivery?.Status == DeliveryStatus.IN_TRANSIT.ToString())
                            {
                                <span class="badge bg-warning text-dark px-2.5 py-1.5 fs-7">IN TRANSIT</span>
                            }
                            else if (dwp.Delivery?.Status == DeliveryStatus.REJECTED.ToString())
                            {
                                <span class="badge bg-danger px-2.5 py-1.5 fs-7">REJECTED</span>
                            }
                            else if (dwp.Delivery?.Status == DeliveryStatus.RECEIVED.ToString())
                            {
                                <span class="badge bg-success px-2.5 py-1.5 fs-7">RECEIVED</span>
                            }
                            else
                            {
                                <span class="badge bg-info px-2.5 py-1.5 fs-7">@dwp.Delivery?.Status</span>
                            }
                        </td>
                        <td colspan="2" class="text-end px-4">
                            <div class="d-inline-flex gap-2">
                                @if (User.IsInRole(UserTypeOptions.Administrator.ToString()) || User.IsInRole(UserTypeOptions.Manager.ToString()))
                                {
                                    <a class="btn btn-sm btn-outline-primary" asp-controller="Deliveries" asp-action="Update" asp-route-id="@dwp.Delivery?.DeliveryID" role="button">Update</a>
                                    <button class="btn btn-sm btn-outline-danger delete-btn" data-deliveryID="@dwp.Delivery?.DeliveryID">Delete</button>
                                }
                                @if (User.IsInRole(UserTypeOptions.Operator.ToString()) && dwp.Delivery?.Status == DeliveryStatus.IN_TRANSIT.ToString())
                                {
                                    <button class="btn btn-sm btn-primary update-status-button" data-deliveryID="@dwp.Delivery?.DeliveryID">Set as received</button>
                                }
                            </div>
                        </td>
                    </tr>

                    @if (dwp.Items is not null && dwp.Items.Any())
                    {
                        <tr class="bg-light-subtle">
                            <td colspan="5" class="p-0 border-0">
                                <div class="px-4 py-2 bg-light text-muted small fw-semibold border-bottom d-flex gap-4">
                                    <span>Included Products:</span>
                                </div>
                                <div class="table-responsive px-4 py-2 bg-light-subtle">
                                    <table class="table table-sm table-borderless align-middle mb-0 small" style="table-layout: fixed; width: 100%;">
                                        <thead>
                                            <tr class="text-secondary border-bottom">
                                                <th class="py-2" style="width: 35%;">Product Name</th>
                                                <th class="py-2" style="width: 20%;">SKU</th>
                                                <th class="py-2 text-center" style="width: 15%;">Quantity</th>
                                                <th class="py-2 text-end" style="width: 15%;">Price at Sale</th>
                                                <th class="py-2 text-end" style="width: 15%;">Unit Price</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (DeliveryItemResponse item in dwp.Items)
                                            {
                                                <tr class="border-bottom-dashed text-dark">
                                                    <td class="py-2 fw-medium text-truncate">@item.ProductName</td>
                                                    <td class="py-2 text-monospace text-truncate">@item.SKU</td>
                                                    <td class="py-2 text-center fw-bold">@item.Quantity</td>
                                                    <td class="py-2 text-end text-success fw-medium">@item.PriceAtSale</td>
                                                    <td class="py-2 text-end text-muted">@item.ProductUnitPrice</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            }
        </table>
    </div>
</div>

@if (User.IsInRole(UserTypeOptions.Administrator.ToString()) || User.IsInRole(UserTypeOptions.Manager.ToString()))
{
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete delivery information</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this delivery entry?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-danger" data-bs-dismiss="modal" id="modal-delete-btn">Delete</button>
                </div>
            </div>
        </div>
    </div>

    @section Scripts
    {
        <script>
            const modalElement = document.getElementById('deleteModal');
            const deleteBtns = document.querySelectorAll(".delete-btn");
            const modalDeleteBtn = document.getElementById('modal-delete-btn');
            let currentDeliveryId = '';
            const myModal = new bootstrap.Modal(modalElement);

            deleteBtns.forEach((btn) => {
                btn.addEventListener('click', () => {
                    currentDeliveryId = btn.getAttribute('data-deliveryID');
                    myModal.show();
                });
            });

            modalDeleteBtn.addEventListener('click', async () => {
                try
                {
                    if (currentDeliveryId == "")
                    {
                        return;
                    }
                    var response = await fetch(`/Deliveries/Delete/${currentDeliveryId}`, {method: "DELETE"});
                    var responseBody = await response.text();
                    const toastContainer = document.getElementById("toast");
                    toastContainer.innerHTML = responseBody;

                    const deliveryToDelete = document.querySelector(`button[data-deliveryID="${currentDeliveryId}"]`).closest(".delivery-record");
                    if(deliveryToDelete)
                    {
                        deliveryToDelete.remove();
                    }

                    const toastElement = document.querySelector(".toast");
                    if (toastElement) {
                        const bootstrapToast = new bootstrap.Toast(toastElement);
                        bootstrapToast.show();
                    }
                }
                catch (error)
                {
                    console.error(error);
                }
            });

        </script>
    }
}



@if (User.IsInRole(UserTypeOptions.Operator.ToString()))
{
    <div class="modal fade" id="update-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Set delivery as received</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to set this delivery as received?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal" id="modal-update-btn">Set as Received</button>
                </div>
            </div>
        </div>
    </div>


    @section Scripts
    {
        <script>
            const updateStatusButtons = document.querySelectorAll(".update-status-button");
            let currentDeliveryID = '';
            const modalUpdateBtn = document.getElementById('modal-update-btn');

            const updateModal = new bootstrap.Modal(document.getElementById('update-modal'));

            updateStatusButtons.forEach(button => {
                button.addEventListener("click", () => {
                    currentDeliveryID = button.getAttribute("data-deliveryID");
                    updateModal.show();
                });
            });

            modalUpdateBtn.addEventListener("click", async () => {
                    try{
                       var response = await fetch('/Deliveries/SetAsReceived', {
                                                    method: "POST",
                                                    headers: {
                                                        "Content-Type": "application/json"
                                                    },
                                                    body: JSON.stringify(currentDeliveryID)
                                                });
                        var responseBody = await response.text();
                        const toastContainer = document.getElementById("toast");
                        toastContainer.innerHTML = responseBody;

                        const updateBtn = document.querySelector(`[data-deliveryID="${currentDeliveryID}"]`);
                        const row = updateBtn?.closest("tr");

                        const deliveryStatusCell = row.querySelector('.delivery-status');

                        if (deliveryStatusCell && updateBtn) {
                            deliveryStatusCell.textContent = "RECEIVED";
                            updateBtn.remove();
                        }

                        const toastElement = document.querySelector(".toast");
                        if (toastElement) {
                            const bootstrapToast = new bootstrap.Toast(toastElement);
                            bootstrapToast.show();
                        }
                    }
                    catch (error)
                    {
                        console.error(error);
                    }

               
            });
        </script>
    }
}
