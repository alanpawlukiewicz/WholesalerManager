@model UpdateDeliveryWithProductsViewModel
@{
    ViewBag.Title = "Update delivery status";
}

<h1>Update Delivery</h1>

<form id="deliveryUpdateForm" asp-controller="Deliveries" asp-action="Update" method="post">
    <div class="form-group">
        <input asp-for="Delivery.DeliveryID" type="hidden">

        <div class="mb-3">
            <label asp-for="Delivery.SupplierID" class="form-label">Supplier</label>
            <select class="form-select" asp-for="Delivery.SupplierID" asp-items="@ViewBag.Suppliers">
                <option value="">Select Supplier</option>
            </select>
            <span asp-validation-for="Delivery.SupplierID" class="text-danger"></span>
            @* <div class="form-text"></div> *@
        </div>

        <div class="mb-3">
            <label asp-for="Delivery.OrderDate" class="form-label">Order Date</label>
            <input asp-for="Delivery.OrderDate" class="form-control" />
            <span asp-validation-for="Delivery.OrderDate" class="text-danger"></span>
            @* <div class="form-text"></div> *@
        </div>

        <div class="mb-3">
            <label asp-for="Delivery.Status" class="form-label">Status</label>
            <select class="form-select" asp-for="Delivery.Status">
                @foreach (var status in Enum.GetNames<DeliveryStatus>())
                {
                    if (Model.Delivery?.Status is not null)
                    {
                        if (status == Model.Delivery?.Status.ToString())
                        {
                            <option selected="selected" value="@status">@status</option>
                        }
                        else
                        {
                            <option value="@status">@status</option>
                        }
                    }
                    else
                    {
                        <option value="@status">@status</option>
                    }

                }
            </select>
            <span asp-validation-for="Delivery.Status" class="text-danger"></span>
            @* <div class="form-text"></div> *@
        </div>

        <div id="products">
            @if (Model.Items is not null)
            {
                @for (int i = 0; i < Model.Items.Count(); i++)
                {
                    @await Component.InvokeAsync("UpdateDeliveryItem", new
                    {
                        index = @i,
                        deliveryID = Model.Delivery!.DeliveryID
                    })
                }
                
            }
                
        </div>
        
        <div class="mb-3">
            <button type="button" class="btn btn-secondary" id="addProductBtn">Add New Product</button>
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">Update</button>
        </div>
    </div>
</form>

@section Scripts
{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer" asp-fallback-test="window.jQuery" asp-fallback-src="~/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js" integrity="sha512-KFHXdr2oObHKI9w4Hv1XPKc898mE4kgYx58oqsc/JqqdLMDI4YjOLzom+EMlW8HFUd0QfjfAvxSL6sEq/a42fQ==" crossorigin="anonymous" referrerpolicy="no-referrer" asp-fallback-test="window.jQuery.validator" asp-fallback-src="~/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js" integrity="sha512-xq+Vm8jC94ynOikewaQXMEkJIOBp7iArs3IhFWSWdRT3Pq8wFz46p+ZDFAR7kHnSFf+zUv52B3prRYnbDRdgog==" crossorigin="anonymous" referrerpolicy="no-referrer" asp-fallback-test="window.jQuery.validator.unobtrusive" asp-fallback-src="~/jquery.validate.unobtrusive.min.js"></script>

    <script>
        // Reset cleint-side validation
        function reinitializeValidation(formSelector) {
            const $form = $(formSelector);

            $form.removeData("validator");
            $form.removeData("unobtrusiveValidation");

            $.validator.unobtrusive.parse($form);
        }

        let i = @Model.Items?.Count()
        const addBtn = document.getElementById("addProductBtn");
        const productsContainer = document.getElementById("products");

        // Add new product to form
        addBtn.addEventListener("click", async () => {
            try
            {
                var response = await fetch(`get-update-product/${i}/${'@Model.Delivery!.DeliveryID'}`, {method: "GET"});
                var responseBody = await response.text();
                productsContainer.insertAdjacentHTML('beforeend', responseBody);
                i++;

                reinitializeValidation('#deliveryUpdateForm');
            }
            catch (error)
            {
                console.error(error);
            }
            
        });

        // Automatically insert product price inside 'Current Price'
        document.addEventListener('change', function (e) {
            if (e.target && e.target.classList.contains('product-select')) {
                const select = e.target;
                const selectedOption = select.options[select.selectedIndex];
                const price = selectedOption.getAttribute('data-price');

                const parent = select.closest('.mb-3');
                const priceInput = parent.querySelector('.price-input');

                if (priceInput) {
                    priceInput.value = price || 0;
                }
            }
        });
    </script>
}

