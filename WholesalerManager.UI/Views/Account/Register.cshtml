@model RegisterDTO
@{
    ViewBag.Title = "Register New User";
}

<div class="card shadow-sm max-width-600 mx-auto my-4">
    <div class="card-header bg-light py-3">
        <h1 class="h3 mb-0 text-primary">Register New User</h1>
    </div>
    <div class="card-body p-4 pt-2">
        <partial name="_formValidationErrorsPartialView" />

        <form asp-controller="Account" asp-action="Register" method="post">
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="FirstName" class="form-label fw-medium">First Name</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="LastName" class="form-label fw-medium">Last Name</label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-medium">Email Address</label>
                <input asp-for="Email" class="form-control" type="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Phone" class="form-label fw-medium">Phone Number</label>
                <input asp-for="Phone" class="form-control" type="tel" />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="UserType" class="form-label fw-medium">Account Type</label>
                <select class="form-select" asp-for="UserType">
                    @foreach (var userType in Enum.GetNames<UserTypeOptions>())
                    {
                        @if (userType == UserTypeOptions.Administrator.ToString() && !User.IsInRole(UserTypeOptions.Administrator.ToString()))
                        {
                            continue;
                        }
                        @if (userType == UserTypeOptions.Manager.ToString() &&
                        (!User.IsInRole(UserTypeOptions.Administrator.ToString()) && !User.IsInRole(UserTypeOptions.Manager.ToString())))
                        {
                            continue;
                        }
                        <option value="@userType">@userType</option>
                    }
                </select>
                <span asp-validation-for="UserType" class="text-danger small"></span>
            </div>

            <div class="card bg-light border-light-subtle p-3 mb-4">
                <div class="form-check">
                    <input type="checkbox" id="has-password" checked="checked" class="form-check-input" />
                    <label class="form-check-label fw-medium text-secondary" for="has-password">
                        Automatically generate password
                    </label>
                </div>

                <div class="mt-3 d-none" id="password-container">
                    <label asp-for="Password" class="form-label fw-medium">Password</label>
                    <input asp-for="Password" class="form-control" type="password" id="password-input" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 border-top pt-3">
                <a asp-controller="Account" asp-action="Users" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary px-4">Register User</button>
            </div>
        </form>
    </div>
</div>

@section Scripts
{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer" asp-fallback-test="window.jQuery" asp-fallback-src="~/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js" integrity="sha512-KFHXdr2oObHKI9w4Hv1XPKc898mE4kgYx58oqsc/JqqdLMDI4YjOLzom+EMlW8HFUd0QfjfAvxSL6sEq/a42fQ==" crossorigin="anonymous" referrerpolicy="no-referrer" asp-fallback-test="window.jQuery.validator" asp-fallback-src="~/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js" integrity="sha512-xq+Vm8jC94ynOikewaQXMEkJIOBp7iArs3IhFWSWdRT3Pq8wFz46p+ZDFAR7kHnSFf+zUv52B3prRYnbDRdgog==" crossorigin="anonymous" referrerpolicy="no-referrer" asp-fallback-test="window.jQuery.validator.unobtrusive" asp-fallback-src="~/jquery.validate.unobtrusive.min.js"></script>

    <script>
        const hasPassword = document.getElementById("has-password");
        const passwordInput = document.getElementById("password-input");
        const passwordContainer = document.getElementById("password-container");

        hasPassword.addEventListener("change", () => {
            if (hasPassword.checked)
            {
                passwordContainer.classList.add("d-none");
                passwordInput.value = null;
            }
            else
            {
                passwordContainer.classList.remove("d-none");
            }
        })
    </script>
}