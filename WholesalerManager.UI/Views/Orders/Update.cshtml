@model UpdateOrderWithProductsViewModel
@{
    ViewBag.Title = "Update Order";
}

<div class="card shadow-sm max-width-800 mx-auto my-4">
    <div class="card-header bg-light py-3">
        <h1 class="h3 mb-0 text-primary">Update Order</h1>
    </div>
    <div class="card-body p-4">
        <form id="orderUpdateForm" asp-controller="Orders" asp-action="Update" method="post">
            <input asp-for="Order.OrderID" type="hidden" />

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="Order.CustomerID" class="form-label fw-medium">Customer</label>
                    <select class="form-select" asp-for="Order.CustomerID" asp-items="@ViewBag.Customers">
                        <option value="">Select Customer</option>
                    </select>
                    <span asp-validation-for="Order.CustomerID" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Order.OrderDate" class="form-label fw-medium">Order Date</label>
                    <input asp-for="Order.OrderDate" class="form-control" />
                    <span asp-validation-for="Order.OrderDate" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Order.Status" class="form-label fw-medium">Order Status</label>
                <select class="form-select" asp-for="Order.Status">
                    @foreach (var status in Enum.GetNames<OrderStatus>())
                    {
                        if (Model.Order?.Status is not null && status == Model.Order.Status.ToString())
                        {
                            <option selected="selected" value="@status">@status</option>
                        }
                        else
                        {
                            <option value="@status">@status</option>
                        }
                    }
                </select>
                <span asp-validation-for="Order.Status" class="text-danger small"></span>
            </div>

            <div class="border-top pt-4 mb-3">
                <h5 class="text-secondary fw-bold mb-3">Ordered Items</h5>
                <div id="products">
                    @if (Model.Items is not null)
                    {
                        @for (int i = 0; i < Model.Items.Count(); i++)
                        {
                            @await Component.InvokeAsync("UpdateOrderItem", new
                            {
                                index = i,
                                orderID = Model.Order!.OrderID
                            })
                        }
                    }
                </div>
            </div>

            <div class="mb-4">
                <button type="button" class="btn btn-outline-primary d-inline-flex align-items-center gap-2" id="addProductBtn">
                    Add New Product
                </button>
            </div>

            <div class="d-flex justify-content-end gap-2 border-top pt-3">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary px-4">Update Order</button>
            </div>
        </form>
    </div>
</div>

@section Scripts
{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer" asp-fallback-test="window.jQuery" asp-fallback-src="~/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js" integrity="sha512-KFHXdr2oObHKI9w4Hv1XPKc898mE4kgYx58oqsc/JqqdLMDI4YjOLzom+EMlW8HFUd0QfjfAvxSL6sEq/a42fQ==" crossorigin="anonymous" referrerpolicy="no-referrer" asp-fallback-test="window.jQuery.validator" asp-fallback-src="~/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js" integrity="sha512-xq+Vm8jC94ynOikewaQXMEkJIOBp7iArs3IhFWSWdRT3Pq8wFz46p+ZDFAR7kHnSFf+zUv52B3prRYnbDRdgog==" crossorigin="anonymous" referrerpolicy="no-referrer" asp-fallback-test="window.jQuery.validator.unobtrusive" asp-fallback-src="~/jquery.validate.unobtrusive.min.js"></script>

    <script>
        // Reset cleint-side validation
        function reinitializeValidation(formSelector) {
            const $form = $(formSelector);

            $form.removeData("validator");
            $form.removeData("unobtrusiveValidation");

            $.validator.unobtrusive.parse($form);
        }

        let i = @Model.Items?.Count()
        const addBtn = document.getElementById("addProductBtn");
        const productsContainer = document.getElementById("products");

        // Add new product to form
        addBtn.addEventListener("click", async () => {
            try
            {
                var response = await fetch(`get-update-product/${i}/${'@Model.Order!.OrderID'}`, {method: "GET"});
                var responseBody = await response.text();
                productsContainer.insertAdjacentHTML('beforeend', responseBody);
                i++;

                reinitializeValidation('#orderUpdateForm');
            }
            catch (error)
            {
                console.error(error);
            }
            
        });

        // Automatically insert product price inside 'Current Price'
        document.addEventListener('change', function (e) {
            if (e.target && e.target.classList.contains('product-select')) {
                const select = e.target;
                const selectedOption = select.options[select.selectedIndex];
                const price = selectedOption.getAttribute('data-price');

                const parent = select.closest('.mb-3');
                const priceInput = parent.querySelector('.price-input');

                if (priceInput) {
                    priceInput.value = price || 0;
                }
            }
        });
    </script>
}

