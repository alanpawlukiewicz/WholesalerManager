@model IEnumerable<OrderWithProductsViewModel>
@{
    ViewBag.Title = "Orders";
}

<div class="container-fluid px-4 my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Orders</h1>
        @if (User.IsInRole("Administrator") || User.IsInRole("Manager") || User.IsInRole("Sales"))
        {
            <a asp-controller="Orders" asp-action="Create" class="btn btn-success d-inline-flex align-items-center gap-2">
                Register New Order
            </a>
        }
    </div>

    @await Component.InvokeAsync("FilterSearchBar", new { controllerName = "Orders", actionName = "Index" })


    <div class="table-responsive shadow-sm rounded border">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(OrderResponse.CustomerName), displayName = "Customer Name" })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(OrderResponse.TIN), displayName = "TIN" })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(OrderResponse.OrderDate), displayName = "Order Date" })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(OrderResponse.Status), displayName = "Status" })
                    <th colspan="2" class="text-end px-4" style="width: 250px;">Actions</th>
                </tr>
            </thead>

            @foreach (var dwp in Model)
            {
                <tbody class="delivery-record border-bottom border-light-subtle">
                    <tr class="table-group-divider border-light-subtle">
                        <td class="fw-bold text-primary">
                            @dwp.Order?.CustomerName
                        </td>
                        <td class="text-monospace">
                            @dwp.Order?.TIN
                        </td>
                        <td>
                            @dwp.Order?.OrderDate
                        </td>
                        <td class="order-status">
                            @if (dwp.Order?.Status == OrderStatus.DELIVERED.ToString())
                            {
                                <span class="badge bg-success px-2.5 py-1.5 fs-7">DELIVERED</span>
                            }
                            else if (dwp.Order?.Status == OrderStatus.CANCELLED.ToString())
                            {
                                <span class="badge bg-danger px-2.5 py-1.5 fs-7">CANCELLED</span>
                            }
                            else if (dwp.Order?.Status == OrderStatus.PENDING.ToString())
                            {
                                <span class="badge bg-warning text-dark px-2.5 py-1.5 fs-7">PENDING</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark px-2.5 py-1.5 fs-7">@dwp.Order?.Status</span>
                            }
                        </td>
                        <td colspan="2" class="text-end px-4">
                            <div class="d-inline-flex gap-2">
                                @if (User.IsInRole(UserTypeOptions.Administrator.ToString()) || User.IsInRole(UserTypeOptions.Manager.ToString()))
                                {
                                    <a class="btn btn-sm btn-outline-primary" asp-controller="Orders" asp-action="Update" asp-route-id="@dwp.Order?.OrderID" role="button">Update</a>
                                    <button class="btn btn-sm btn-outline-danger delete-btn" data-deliveryID="@dwp.Order?.OrderID">Delete</button>
                                }
                                @if (User.IsInRole(UserTypeOptions.Sales.ToString()) && dwp.Order?.Status != OrderStatus.DELIVERED.ToString() && dwp.Order?.Status != OrderStatus.CANCELLED.ToString())
                                {
                                    <form asp-controller="Orders" asp-action="CancelOrder" asp-route-id="@dwp.Order?.OrderID" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-warning">Cancel Order</button>
                                    </form>
                                }
                                @if (User.IsInRole(UserTypeOptions.Operator.ToString()) && (dwp.Order?.Status == OrderStatus.PENDING.ToString() || dwp.Order?.Status == OrderStatus.PAID.ToString() || dwp.Order?.Status == OrderStatus.PROCESSING.ToString()))
                                {
                                    <button class="btn btn-sm btn-primary update-status-btn" data-deliveryID="@dwp.Order?.OrderID">Update Status</button>
                                }
                            </div>
                        </td>
                    </tr>

                    @if (dwp.Items is not null && dwp.Items.Any())
                    {
                        <tr class="bg-light-subtle">
                            <td colspan="5" class="p-0 border-0">
                                <div class="px-4 py-2 bg-light text-muted small fw-semibold border-bottom border-light-subtle d-flex gap-4">
                                    <span>Ordered Products:</span>
                                </div>
                                <div class="table-responsive px-4 py-2 bg-light-subtle">
                                    <table class="table table-sm table-borderless align-middle mb-0 small" style="table-layout: fixed; width: 100%;">
                                        <thead>
                                            <tr class="text-secondary border-bottom border-light-subtle">
                                                <th class="py-2" style="width: 35%;">Product Name</th>
                                                <th class="py-2" style="width: 20%;">SKU</th>
                                                <th class="py-2 text-center" style="width: 15%;">Quantity</th>
                                                <th class="py-2 text-end" style="width: 15%;">Price at Sale</th>
                                                <th class="py-2 text-end" style="width: 15%;">Unit Price</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (OrderItemResponse? item in dwp.Items)
                                            {
                                                <tr class="text-dark border-bottom" style="border-color: rgba(0, 0, 0, 0.05) !important;">
                                                    <td class="py-2 fw-medium text-truncate">@item?.ProductName</td>
                                                    <td class="py-2 text-monospace text-truncate">@item?.SKU</td>
                                                    <td class="py-2 text-center fw-bold">@item?.Quantity</td>
                                                    <td class="py-2 text-end text-success fw-medium">@item?.PriceAtSale</td>
                                                    <td class="py-2 text-end text-muted">@item?.ProductUnitPrice</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            }
        </table>
    </div>
</div>

@if (User.IsInRole("Administrator") || User.IsInRole("Manager"))
{
    <div class="modal fade" id="delete-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete order information</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this order entry?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-danger" data-bs-dismiss="modal" id="modal-delete-btn">Delete</button>
                </div>
            </div>
        </div>
    </div>

    @section Scripts
    {
        <script>
            const modalElement = document.getElementById('delete-modal');
            const deleteBtns = document.querySelectorAll(".delete-btn");
            const modalDeleteBtn = document.getElementById('modal-delete-btn');
            let currentOrderId = '';
            const myModal = new bootstrap.Modal(modalElement);

            deleteBtns.forEach((btn) => {
                btn.addEventListener('click', () => {
                    currentOrderId = btn.getAttribute('data-deliveryID');
                    myModal.show();
                });
            });

            modalDeleteBtn.addEventListener('click', async () => {
                try
                {
                    if (currentOrderId == "")
                    {
                        return;
                    }
                    var response = await fetch(`Delete/${currentOrderId}`, {method: "DELETE"});
                    var responseBody = await response.text();
                    const toastContainer = document.getElementById("toast");
                    toastContainer.innerHTML = responseBody;

                    const orderToDelete = document.querySelector(`button[data-deliveryID="${currentOrderId}"]`).closest(".delivery-record");
                    if(orderToDelete)
                    {
                        orderToDelete.remove();
                    }

                    const toastElement = document.querySelector(".toast");
                    if (toastElement) {
                        const bootstrapToast = new bootstrap.Toast(toastElement);
                        bootstrapToast.show();
                    }
                }
                catch (error)
                {
                    console.error(error);
                }
            });

        </script>
    }

}


@if (User.IsInRole("Operator"))
{
    <div class="modal fade" id="change-status-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Update order status</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to change the status of this order to <span id="new-status"></span>?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-danger" data-bs-dismiss="modal" id="modal-update-status-btn">Update Status</button>
                </div>
            </div>
        </div>
    </div>

    
    @section Scripts
    {
        <script>
            const modalElement = document.getElementById('change-status-modal');
            const updateBtns = document.querySelectorAll(".update-status-btn");
            const modalUpdateStatusBtn = document.getElementById('modal-update-status-btn');
            let currentOrderId = '';
            let newStatus = '';
            let statusSpan = document.getElementById("new-status");
            const myModal = new bootstrap.Modal(modalElement);

            updateBtns.forEach((btn) => {
                btn.addEventListener('click', () => {
                    currentOrderId = btn.getAttribute('data-deliveryID');

                    newStatus = btn.closest("tr").querySelector(".order-status").textContent.trim();

                    if (newStatus == "PENDING")
                    {
                        newStatus = "PAID";
                    }
                    else if (newStatus == "PAID")
                    {
                        newStatus = "PROCESSING";
                    }
                    else if (newStatus == "PROCESSING")
                    {
                        newStatus = "SHIPPED";
                    }

                    statusSpan.innerText = newStatus;
                    myModal.show();
                });
            });

            modalUpdateStatusBtn.addEventListener('click', async () => {
                try
                {
                    if (currentOrderId == "")
                    {
                        return;
                    }
                    var response = await fetch(`UpdateOrderStatus/${currentOrderId}/${newStatus}`, {method: "POST"});
                    var responseBody = await response.text();
                    const toastContainer = document.getElementById("toast");
                    toastContainer.innerHTML = responseBody;

                    const updateBtn = document.querySelector(`button[data-deliveryID="${currentOrderId}"]`);
                    const orderToUpdate = updateBtn?.closest("tr").querySelector(".order-status");

                    if(orderToUpdate)
                    {
                        orderToUpdate.innerText = newStatus;
                    }
                    if (updateBtn)
                    {
                        if (newStatus == "SHIPPED")
                        {
                            updateBtn.remove();
                        }
                    }

                    const toastElement = document.querySelector(".toast");
                    if (toastElement) {
                        const bootstrapToast = new bootstrap.Toast(toastElement);
                        bootstrapToast.show();
                    }
                }
                catch (error)
                {
                    console.error(error);
                }
            });

        </script>
    }
}
