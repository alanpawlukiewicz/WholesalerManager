@model CustomerAddRequest
@{
    ViewBag.Title = "Register Customer";
}

<div class="card shadow-sm max-width-600 mx-auto my-4">
    <div class="card-header bg-light py-3">
        <h1 class="h3 mb-0 text-primary">Register New Customer</h1>
    </div>
    <div class="card-body p-4">
        <form asp-controller="Customers" asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="CustomerName" class="form-label fw-medium">Customer Name</label>
                <input asp-for="CustomerName" class="form-control" />
                <span asp-validation-for="CustomerName" class="text-danger small"></span>
            </div>

            <div class="form-check mb-3">
                <input type="checkbox" id="has-tin" checked="checked" class="form-check-input" />
                <label class="form-check-label fw-medium" for="has-tin">
                    The customer has a TIN
                </label>
            </div>

            <div class="mb-3" id="tin-container">
                <label asp-for="TIN" class="form-label fw-medium">Taxpayer Identification Number (TIN)</label>
                <input asp-for="TIN" class="form-control" id="tin-input" />
                <span asp-validation-for="TIN" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ContactEmail" class="form-label fw-medium">Contact Email</label>
                <input asp-for="ContactEmail" class="form-control" />
                <span asp-validation-for="ContactEmail" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Address" class="form-label fw-medium">Address</label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary px-4">Register</button>
            </div>
        </form>
    </div>
</div>


@section Scripts
{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer" asp-fallback-test="window.jQuery" asp-fallback-src="~/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js" integrity="sha512-KFHXdr2oObHKI9w4Hv1XPKc898mE4kgYx58oqsc/JqqdLMDI4YjOLzom+EMlW8HFUd0QfjfAvxSL6sEq/a42fQ==" crossorigin="anonymous" referrerpolicy="no-referrer" asp-fallback-test="window.jQuery.validator" asp-fallback-src="~/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js" integrity="sha512-xq+Vm8jC94ynOikewaQXMEkJIOBp7iArs3IhFWSWdRT3Pq8wFz46p+ZDFAR7kHnSFf+zUv52B3prRYnbDRdgog==" crossorigin="anonymous" referrerpolicy="no-referrer" asp-fallback-test="window.jQuery.validator.unobtrusive" asp-fallback-src="~/jquery.validate.unobtrusive.min.js"></script>

    <script>
        const hasTin = document.getElementById("has-tin");
        const tinInput = document.getElementById("tin-input");
        const tinContainer = document.getElementById("tin-container");

        hasTin.addEventListener("change", () => {
            if (hasTin.checked)
            {
                tinContainer.classList.remove("d-none");
            }
            else
            {
                tinContainer.classList.add("d-none");
                tinInput.value = null;
            }
        })
    </script>
}
