@model IEnumerable<CustomerResponse>
@{
    ViewBag.Title = "Customers";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Customers</h1>
        <a asp-controller="Customers" asp-action="Create" class="btn btn-success d-inline-flex align-items-center gap-2">
            Register New Customer
        </a>
    </div>

    @await Component.InvokeAsync("FilterSearchBar", new { controllerName = "Customers", actionName = "Index" })

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-light">
                <tr>
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(CustomerResponse.CustomerName), displayName = "Customer Name" })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(CustomerResponse.TIN), displayName = "TIN" })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(CustomerResponse.ContactEmail), displayName = "Contact Email" })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(CustomerResponse.Address), displayName = "Address" })
                    <th style="width: 1%;"></th>
                    <th style="width: 1%;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var customer in Model)
                {
                    <tr>
                        <td>@customer.CustomerName</td>
                        <td>@customer.TIN</td>
                        <td>@customer.ContactEmail</td>
                        <td>@customer.Address</td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" asp-controller="Customers" asp-action="Update" asp-route-id="@customer.CustomerID" role="button">Update</a>
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-danger" asp-controller="Customers" asp-action="Delete" asp-route-id="@customer.CustomerID" role="button">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
