@model ProductDeleteRequest
@{
    ViewBag.Title = "Delete Product";
}
<h1 class="h1 text-danger">Delete Product</h1>
<div class="text-danger">Are you sure to delete this product?</div>

<form asp-controller="Products" asp-action="Delete" method="post">
    <div class="mb-3">
        <input asp-for="ProductID" type="hidden">
    </div>
    <div class="mb-3">
        <label asp-for="ProductName" class="form-label">Product Name</label>
        <input asp-for="ProductName" class="form-control" readonly>
        <span asp-validation-for="ProductName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SKU" class="form-label">Stock Keeping Unit (SKU)</label>
        <input asp-for="SKU" class="form-control" readonly>
        <span asp-validation-for="SKU" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StockQuantity" class="form-label">Stock Quantity</label>
        <input asp-for="StockQuantity" class="form-control" readonly>
        <span asp-validation-for="StockQuantity" class="text-danger"></span>
    </div>

    @if(Model.StockQuantity > 0)
    {
        <div class="alert alert-warning" role="alert">
            This product has stock quantity greater than zero. Deleting it may affect inventory management.
        </div>
    }

    <button type="submit" class="btn btn-danger">Delete</button>
</form>