@if (ViewBag.FieldNames is not null)
{
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 w-100 mb-2">
        <form asp-controller="@ViewBag.ControllerName" asp-action="@ViewBag.ActionName" method="get" class="row g-2 align-items-center w-100 m-0 flex-grow-1">
            <div class="col-md-3">
                <select name="propertyName" class="form-select">
                    @foreach (var fieldName in ViewBag.FieldNames)
                    {
                        if (Context.Request.Query["propertyName"] == fieldName)
                        {
                            <option value="@fieldName" selected>@fieldName</option>
                        }
                        else
                        {
                            <option value="@fieldName">@fieldName</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-6">
                <div class="input-group">
                    <input name="filter" class="form-control" placeholder="Filter..." value="@Context.Request.Query["filter"]" />
                    <button class="btn btn-primary d-inline-flex align-items-center gap-2" type="submit">
                        <img src="~/images/search.svg" alt="search" style="width: 16px; height: 16px;" /> Search
                    </button>
                </div>
            </div>

            <div class="col-md-3">
                <div class="form-check m-0">
                    <input type="checkbox" name="ignoreCase" class="form-check-input" id="ignoreCaseCheck" checked value="true" />
                    <label class="form-check-label text-muted small" for="ignoreCaseCheck">Ignore case</label>
                </div>
            </div>
        </form>

        <div class="text-nowrap ms-auto">
            <a asp-action="@ViewBag.ActionName" asp-controller="@ViewBag.ControllerName" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2">
                Clear all filters
            </a>
        </div>
    </div>
}

