@inject UserManager<ApplicationUser> UserManager
@{
    var usr = await UserManager.GetUserAsync(User);
    var fullName = usr?.FirstName + " " + usr?.LastName;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous" asp-fallback-test-class="visually-hidden" asp-fallback-href="~/styles/bootstrap.min.css">
    <link href="~/styles/Style.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous" asp-fallback-test="window.bootstrap && window.bootstrap.Modal" asp-fallback-src="~/bootstrap.bundle.min.js"></script>
</head>
<body>
    <main>
        <div class="container-fluid px-0">
            <header class="navbar navbar-expand-lg navbar-light bg-light border-bottom px-4 py-3 mb-4">
                <div class="container-fluid d-flex flex-wrap justify-content-between align-items-center">
                    <a href="/" class="d-flex align-items-center mb-2 mb-md-0 me-md-auto link-body-emphasis text-decoration-none">
                        <span class="fs-4 fw-semibold text-primary">Wholesaler Panel</span>
                    </a>

                    <ul class="nav nav-pills align-items-center gap-1">
                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a asp-controller="Home" asp-action="Index" class="nav-link">Home</a>
                            </li>
                        }
                        
                        @if (User.IsInRole("Administrator") || User.IsInRole("Manager") || User.IsInRole("Sales") || User.IsInRole("Operator"))
                        {
                            <li class="nav-item">
                                <a asp-controller="Products" asp-action="Index" class="nav-link">Products</a>
                            </li>
                        }

                        @if (User.IsInRole("Administrator") || User.IsInRole("Manager") || User.IsInRole("Operator"))
                        {
                            <li class="nav-item">
                                <a asp-controller="Deliveries" asp-action="Index" class="nav-link">Deliveries</a>
                            </li>
                        }

                        @if (User.IsInRole("Administrator") || User.IsInRole("Manager") || User.IsInRole("Sales"))
                        {
                            <li class="nav-item">
                                <a asp-controller="Customers" asp-action="Index" class="nav-link">Customers</a>
                            </li>
                        }

                        @if (User.IsInRole("Administrator") || User.IsInRole("Manager") || User.IsInRole("Sales") || User.IsInRole("Operator"))
                        {
                            <li class="nav-item">
                                <a asp-controller="Orders" asp-action="Index" class="nav-link">Orders</a>
                            </li>
                        }

                        @if (User.IsInRole("Administrator") || User.IsInRole("Manager"))
                        {
                            <li class="nav-item">
                                <a asp-controller="Account" asp-action="Index" class="nav-link">Manage Accounts</a>
                            </li>
                        }

                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item ms-2 align-self-center">
                                <span class="navbar-text fw-medium me-2 text-secondary">@fullName</span>
                            </li>
                            <li class="nav-item">
                                <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm">Log out</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-sm">Log in</a>
                            </li>
                        }
                    </ul>
                </div>
            </header>
        </div>

        <div class="container-fluid px-4">
            @RenderBody()
        </div>
    </main>

<div id="toast">
    <partial name="_errorToastPartialView"></partial>
    <partial name="_infoToastPartialView"></partial>

</div>



<script>
    document.addEventListener('DOMContentLoaded', () => {
    const infoToast = document.getElementById('infoToast');
    if(infoToast)
    {
        const itoast = new bootstrap.Toast(infoToast);
        itoast.show();
    }
    

    const errorToast = document.getElementById('errorToast');
    if (errorToast)
    {
        const etoast = new bootstrap.Toast(errorToast);
        etoast.show();
    }
    
    });
</script>
        
@RenderSection("Scripts", required: false)
</body>
</html>
