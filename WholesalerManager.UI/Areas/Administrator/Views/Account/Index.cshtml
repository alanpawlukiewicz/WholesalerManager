@model IEnumerable<UserResponse>
@{
    ViewBag.Title = "Manage Accounts";
}


<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Account Manager</h1>
        <div>
            <a asp-controller="Account" asp-action="Register" class="btn btn-success d-inline-flex align-items-center gap-2">
                Register New Account
            </a>
        </div>

    </div>

    @await Component.InvokeAsync("FilterSearchBar", new { controllerName = "Products", actionName = "Index" })

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-light">
                <tr>
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(UserResponse.FirstName), displayName = "First Name" })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(UserResponse.LastName), displayName = "Last Name" })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(UserResponse.UserName), displayName = "Username" })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(UserResponse.Email), displayName = "Email" })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(UserResponse.PhoneNumber), displayName = "Phone Number" })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(UserResponse.MustChangePassword), displayName = "Must Change Password?" })
                    @await Component.InvokeAsync("TableHeader", new { propertyName = nameof(UserResponse.IsEnabled), displayName = "Is Enabled?" })
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.FirstName</td>
                        <td>@user.LastName</td>
                        <td>@user.UserName</td>
                        <td>@user.Email</td>
                        <td>@user.PhoneNumber</td>
                        <td>
                            @if (user?.MustChangePassword == true)
                            {
                                <span class="badge bg-warning text-dark">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-success">No</span>
                            }
                        </td>
                        <td>
                            @if (user?.IsEnabled == true)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">No</span>
                            }
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" asp-controller="Account" asp-action="Edit" asp-route-id="@user.Id" role="button">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
