@model UserEditRequest
@{
    ViewBag.Title = "Edit Account";
}

<div class="card shadow-sm max-width-600 mx-auto my-4">
    <div class="card-header bg-light py-3">
        <h1 class="h3 mb-0 text-primary">Edit Account</h1>
    </div>
    <div class="card-body p-4 pt-2">
        <partial name="_formValidationErrorsPartialView" />

        <form asp-controller="Account" asp-action="Edit" method="post">
            <input asp-for="Id" type="hidden" />
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label asp-for="FirstName" class="form-label fw-medium">First Name</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="LastName" class="form-label fw-medium">Last Name</label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="UserName" class="form-label fw-medium">Username</label>
                <input asp-for="UserName" class="form-control" />
                <span asp-validation-for="UserName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-medium">Email Address</label>
                <input asp-for="Email" class="form-control" type="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PhoneNumber" class="form-label fw-medium">Phone Number</label>
                <input asp-for="PhoneNumber" class="form-control" type="tel" />
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-end gap-2 border-top py-3">
                <a asp-controller="Account" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary px-4">Edit Account</button>
            </div>
        </form>

        <div class="d-flex justify-content-end gap-2 border-top pt-3">
            <form asp-action="ResetAccountPassword" asp-controller="Account" method="post" asp-route-id="@Model.Id">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning px-4">Reset Password</button>
            </form>

            <form asp-action="ChangeEnabledStatus" asp-controller="Account" method="post" asp-route-id="@Model.Id">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning px-4">Activate/Deactivate Account</button>
            </form>

            <form asp-action="RemoveAccount" asp-controller="Account" method="post" asp-route-id="@Model.Id">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger px-4">Remove Account</button>
            </form>
        </div>
    </div>

</div>
