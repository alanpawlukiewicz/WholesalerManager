@{
    ViewBag.Title = "Administrator Dashboard";
}
<div class="card shadow-sm max-width-600 mx-auto my-5">
    <div class="card-header bg-light py-3 text-center border-bottom-0">
        <div class="text-primary mb-2">
            <img src="~/images/dashboard.svg" alt="dashboard" height="40" width="40" />
        </div>
        <h1 class="h3 mb-0 text-dark fw-bold">Administrator Dashboard</h1>
        <p class="text-muted small mb-0 mt-1">Select an administrative action or view system logs</p>
    </div>

    <div class="card-body p-4">
        <div class="d-grid gap-3">
            <a asp-controller="Account" asp-action="Index" class="btn btn-outline-primary btn-lg text-start d-flex align-items-center justify-content-between p-3 rounded-3 shadow-sm transition-all hover-lift">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-primary-subtle text-primary p-2 rounded-circle">
                        <img src="~/images/group.svg" alt="group" height="20" width="20" />
                    </div>
                    <div>
                        <div class="fw-bold fs-6">Manage Accounts</div>
                        <div class="small text-muted fw-normal">Create, edit, and control system user access</div>
                    </div>
                </div>
                <span class="text-primary">&rarr;</span>
            </a>

            <a asp-controller="Logging" asp-action="AuditLogs" class="btn btn-outline-secondary btn-lg text-start d-flex align-items-center justify-content-between p-3 rounded-3 shadow-sm transition-all hover-lift">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-secondary-subtle text-secondary p-2 rounded-circle">
                        <img src="~/images/shield_lock.svg" alt="shield" height="20" width="20" />
                    </div>
                    <div>
                        <div class="fw-bold fs-6">Browse Audit Logs</div>
                        <div class="small text-muted fw-normal">Monitor security actions and user operations</div>
                    </div>
                </div>
                <span class="text-secondary">&rarr;</span>
            </a>

            <a asp-controller="Logging" asp-action="InventoryLogs" class="btn btn-outline-secondary btn-lg text-start d-flex align-items-center justify-content-between p-3 rounded-3 shadow-sm transition-all hover-lift">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-secondary-subtle text-secondary p-2 rounded-circle">
                        <img class="" src="~/images/package.svg" alt="package" height="20" width="20" />
                    </div>
                    <div>
                        <div class="fw-bold fs-6">Browse Inventory Logs</div>
                        <div class="small text-muted fw-normal">Track stock alterations and warehouse actions</div>
                    </div>
                </div>
                <span class="text-secondary">&rarr;</span>
            </a>
        </div>
    </div>
</div>