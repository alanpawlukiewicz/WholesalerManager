@{
    ViewBag.Title = "Manager Dashboard";
}

<div class="card shadow-sm max-width-600 mx-auto my-5">
    <div class="card-header bg-light py-3 text-center border-bottom-0">
        <div class="text-primary mb-2">
            <img src="~/images/dashboard.svg" alt="dashboard" height="40" width="40" />
        </div>
        <h1 class="h3 mb-0 text-dark fw-bold">Manager Dashboard</h1>
        <p class="text-muted small mb-0 mt-1">Oversee supply supply pipelines, pending inventory levels, and client orders</p>
    </div>

    <div class="card-body p-4 pt-2">
        @if (ViewBag.NumberofProductsNeedingReorder > 0)
        {
            <div class="alert alert-warning d-flex align-items-center gap-3 border-warning mb-4 shadow-sm" role="alert">
                <div class="text-warning-emphasis">
                    <img src="~/images/warning.svg" alt="warning" height="20" width="20" />
                </div>
                <div>
                    <span class="fw-bold text-warning-emphasis">Supply Alert:</span> There are <span class="badge bg-warning text-dark fw-bold">@ViewBag.NumberofProductsNeedingReorder</span> products that urgently require restocking.
                </div>
            </div>
        }

        <div class="d-grid gap-3">
            <a asp-controller="Products" asp-action="ProductsNeedingReorder" class="btn btn-outline-danger btn-lg text-start d-flex align-items-center justify-content-between p-3 rounded-3 shadow-sm transition-all hover-lift">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-danger-subtle text-danger p-2 rounded-circle">
                        <img src="~/images/reorder.svg" alt="reorder" height="20" width="20" />
                    </div>
                    <div>
                        <div class="fw-bold fs-6">Manage Products Needing Reorder</div>
                        <div class="small text-muted fw-normal">Verify low stock units and execute renewal pipelines</div>
                    </div>
                </div>
                <span class="text-danger">&rarr;</span>
            </a>

            <a asp-controller="Products" asp-action="Index" asp-area="" class="btn btn-outline-secondary btn-lg text-start d-flex align-items-center justify-content-between p-3 rounded-3 shadow-sm transition-all hover-lift">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-secondary-subtle text-secondary p-2 rounded-circle">
                        <img src="~/images/box.svg" alt="box" height="20" width="20" />
                    </div>
                    <div>
                        <div class="fw-bold fs-6">Manage Products</div>
                        <div class="small text-muted fw-normal">Control item definitions, basic units, and overall safety stock</div>
                    </div>
                </div>
                <span class="text-secondary">&rarr;</span>
            </a>

            <a asp-controller="Orders" asp-action="Index" asp-area="" class="btn btn-outline-secondary btn-lg text-start d-flex align-items-center justify-content-between p-3 rounded-3 shadow-sm transition-all hover-lift">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-secondary-subtle text-secondary p-2 rounded-circle">
                        <img src="~/images/order_approve.svg" alt="order" height="20" width="20" />
                    </div>
                    <div>
                        <div class="fw-bold fs-6">Manage Orders</div>
                        <div class="small text-muted fw-normal">Evaluate commercial revenue transactions and customer sales</div>
                    </div>
                </div>
                <span class="text-secondary">&rarr;</span>
            </a>

            <a asp-controller="Deliveries" asp-action="Index" asp-area="" class="btn btn-outline-secondary btn-lg text-start d-flex align-items-center justify-content-between p-3 rounded-3 shadow-sm transition-all hover-lift">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-secondary-subtle text-secondary p-2 rounded-circle">
                        <img src="~/images/delivery_truck.svg" alt="truck" height="20" width="20" />
                    </div>
                    <div>
                        <div class="fw-bold fs-6">Manage Deliveries</div>
                        <div class="small text-muted fw-normal">Track inbound supplier fulfillment cargo lists</div>
                    </div>
                </div>
                <span class="text-secondary">&rarr;</span>
            </a>
        </div>
    </div>
</div>